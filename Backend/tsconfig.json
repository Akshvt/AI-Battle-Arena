{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "module": "nodenext",
    "target": "esnext",
    "moduleDetection": "force",
    "skipLibCheck": true,
    "strict": true,
    "sourceMap": true,
    "declaration": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
